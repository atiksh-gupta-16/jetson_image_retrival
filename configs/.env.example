# ── Imagify environment variables ───────────────────────────────────────────
# Copy this file to .env and adjust values for your deployment.

# App
APP_NAME=Imagify
DEBUG=false
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Storage paths (relative to project root or absolute)
IMAGE_STORE_DIR=./data/images
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=imagify_alerts

# CLIP model — change to a larger model for better accuracy
# Options: openai/clip-vit-base-patch32  |  openai/clip-vit-large-patch14
CLIP_MODEL_NAME=openai/clip-vit-base-patch32
# Use "cuda" if your server has a GPU
EMBEDDING_DEVICE=cpu

# Upload limits
MAX_IMAGE_SIZE_MB=20.0

# Retrieval
DEFAULT_TOP_K=10
MAX_TOP_K=50

# Frontend (set this in your Streamlit environment)
# IMAGIFY_API_URL=http://localhost:8000
